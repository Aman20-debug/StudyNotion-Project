# ---- Copy this file to frontend/.env and fill in real values ----
# frontend/.env is git-ignored and must never be committed.
# WARNING: every VITE_ variable is embedded in the public browser bundle.
# Only put PUBLIC values here — never a secret key.

# Public Razorpay key id (NOT the secret)
VITE_RAZORPAY_KEY=your_razorpay_key_id

# Backend API base URL
VITE_BACKEND_URL=http://localhost:4000/api/v1
